# DigitalOcean Gradient API key
# Get from: https://cloud.digitalocean.com/gradient
GRADIENT_API_KEY=your_gradient_api_key_here

# Optional: GitHub token for higher API rate limits (60 -> 5000 req/hr)
GITHUB_TOKEN=your_github_token_here

# Model to use (default: llama3.3-70b-instruct)
GRADIENT_MODEL=llama3.3-70b-instruct

# Frontend (set in Vercel env vars)
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app
